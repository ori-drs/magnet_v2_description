<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="magnet_v2">

  <xacro:macro name="magnet_v2" params="parent *origin prefix:='' name:=magnet_v2 simulation:=false use_gpu:=true">

    <xacro:property name="imu_base_height" value="0.1115"/>
    <link name="${prefix}magnet_v2_base_mount" />
    <joint name="${parent}_to_${prefix}magnet_v2_base_mount" type="fixed">
      <xacro:insert_block name="origin"/>      
      <parent link="${parent}" />
      <child link="${prefix}magnet_v2_base_mount" />
    </joint>

    <joint name="${prefix}magnet_v2_base_mount_to_${prefix}magnet_v2_heatsink_and_case" type="fixed">
      <parent link="${prefix}magnet_v2_base_mount" />
      <child link="${prefix}magnet_v2_heatsink_and_case" />
      <origin xyz="0 0 ${imu_base_height}" rpy="0 0 0" />
    </joint>

    <link name="${prefix}magnet_v2_heatsink_and_case">
      <visual>
        <material name="darkgrey">
          <color rgba="0.3 0.3 0.3 1"/>
        </material>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://magnet_v2_description/meshes/visual/magnet_v2_heatsink_and_case.STL" scale="1 1 1"/>
        </geometry>
      </visual>
    </link>

    <link name="${prefix}left_camera">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://magnet_v2_description/meshes/visual/eCon_cam_Base.STL" scale="1 1 1"/>
        </geometry>
        <material name="darkgrey"/>
      </visual>
    </link>

    <joint name="${prefix}magnet_to_left_camera" type="fixed">
      <parent link="${prefix}magnet_v2_heatsink_and_case"/>
      <child link="${prefix}left_camera"/>
      <origin xyz="0.00 -0.043 -0.011" rpy="${pi/2} ${pi} 0"/>
    </joint>

    <link name="${prefix}centre_camera">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://magnet_v2_description/meshes/visual/eCon_cam_Base.STL" scale="1 1 1"/>
        </geometry>
        <material name="darkgrey"/>
      </visual>
    </link>

    <joint name="${prefix}magnet_to_centre_camera" type="fixed">
      <parent link="${prefix}magnet_v2_heatsink_and_case"/>
      <child link="${prefix}centre_camera"/>
      <origin xyz="-0.043 0.000 -0.011" rpy="${-pi/2} 0 ${pi/2}"/>
    </joint>

    <link name="${prefix}right_camera">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://magnet_v2_description/meshes/visual/eCon_cam_Base.STL" scale="1 1 1"/>
        </geometry>
        <material name="darkgrey"/>
      </visual>
    </link>

    <joint name="${prefix}magnet_to_right_camera" type="fixed">
      <parent link="${prefix}magnet_v2_heatsink_and_case"/>
      <child link="${prefix}right_camera"/>
      <origin xyz="0.000 0.043 -0.011" rpy="${-pi/2} 0 0"/>
    </joint>

    <xacro:include filename="$(find microstrain_inertial_description)/urdf/gx5_25.urdf.xacro"/>
    <xacro:gx5_25 name="${prefix}gx5_25" parent="${prefix}magnet_v2_heatsink_and_case">
      <origin xyz="0.00 0.0 0.0" rpy="${pi} 0 0" />
    </xacro:gx5_25>


    <xacro:include filename="$(find hesai_description)/urdf/hesai_qt64.urdf.xacro"/>

    <xacro:hesai_qt64 name="${prefix}hesai_qt64_device" parent="${prefix}magnet_v2_heatsink_and_case" simulation="${simulation}" use_gpu="${use_gpu}" lidar_frame="${prefix}pandar">
      <origin xyz="0 0 0.01" rpy="0 0 ${pi}" />
    </xacro:hesai_qt64>

  </xacro:macro>

</robot>